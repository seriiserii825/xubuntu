# .conkyrc - Edited from various examples compiled from the Web
# by Xplosive
# by Neonboy

# --- Window Layout & Options --- #
background no
own_window yes
own_window_colour 000000
own_window_transparent yes
own_window_type normal
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
double_buffer yes
use_spacer right
use_xft yes
alignment top_right
gap_x 65
gap_y 142

# --- Colours, Sizes, Fonts & Margins --- #
update_interval 2
maximum_width 230
stippled_borders 3
border_margin 9
border_width 10
default_color ddd
no_buffers yes

# --- Text --- #
draw_outline no
draw_borders no
font Sans:size=10:weight=bold
uppercase no
draw_shades yes
override_utf8_locale yes

own_window_argb_value 0
own_window_argb_visual no
minimum_size 0 0
