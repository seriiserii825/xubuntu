{
   "background": {
      "page": "background.html"
   },
   "browser_action": {
      "default_icon": "icons/button.png",
      "default_popup": "popup.html",
      "default_title": "Vimbox Переводчик от Skyeng"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "includes/content.js" ],
      "matches": [ "http://*/*", "https://*/*", "file:///*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
   "description": "Бесплатный переводчик английских слов и фраз на сайтах. Читайте зарубежные издания и учите английский язык",
   "homepage_url": "http://skyeng.ru/",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/button.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "Vimbox Переводчик от Skyeng",
   "permissions": [ "tabs", "http://*/*", "https://*/*", "contextMenus", "webNavigation", "notifications", "cookies" ],
   "short_name": "Translator",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.8.4",
   "web_accessible_resources": [ "res/*", "assets/*", "icons/*" ]
}
